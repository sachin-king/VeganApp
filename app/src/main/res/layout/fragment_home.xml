<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Search Bar -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            card_view:cardCornerRadius="30dp"
            card_view:cardElevation="4dp">

            <EditText
                android:id="@+id/searchBar"
                android:hint="Search Vegan Restaurants"
                android:textSize="15sp"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:paddingStart="16dp"
                android:background="@android:color/transparent"
                android:drawableStart="@android:drawable/ic_menu_search"
                android:drawablePadding="10dp"/>


        </androidx.cardview.widget.CardView>

        <!-- Filter Button -->
        <Button
            android:id="@+id/btnFilter"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="Filter ▼"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:backgroundTint="@color/green"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="8dp"
            android:paddingHorizontal="16dp"/>



        <!-- Vegan Restaurants -->
        <TextView
            android:text="Vegan Restaurants Nearby"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="#2E7D32"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>


        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- ALL -->
                <TextView
                    android:id="@+id/btnAll"
                    android:text="All"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:background="@drawable/filter_selected_bg"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:layout_marginEnd="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    />

                <!-- VEGAN -->
                <TextView
                    android:id="@+id/btnVegan"
                    android:text="🌿 Vegan"
                    android:textSize="14sp"
                    android:textColor="#333"
                    android:background="@drawable/filter_unselected_bg"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:layout_marginEnd="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    />

                <!-- OPEN -->
                <TextView
                    android:id="@+id/btnOpen"
                    android:text="🟢 Open"
                    android:textSize="14sp"
                    android:textColor="#333"
                    android:background="@drawable/filter_unselected_bg"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:layout_marginEnd="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    />

                <!-- CLOSED -->
                <TextView
                    android:id="@+id/btnClosed"
                    android:text="🔴 Closed"
                    android:textSize="14sp"
                    android:textColor="#333"
                    android:background="@drawable/filter_unselected_bg"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:layout_marginEnd="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    />

            </LinearLayout>

        </HorizontalScrollView>



        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/restaurantRecycler"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:padding="4dp"/>



        <!-- Trending Recipes -->
        <TextView
            android:text="Trending Recipes"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="#2E7D32"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recipeRecycler"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:padding="4dp"
            android:clipToPadding="false"/>


        <!-- Categories -->
        <TextView
            android:text="Categories"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="#2E7D32"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/categoryRecycler"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="4dp"/>

    </LinearLayout>

</ScrollView>
